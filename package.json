{
  "name": "blog",
  "version": "1.0.0",
  "license": "MIT",
  "description": "Markdown blog generated from Ghost content",
  "private": true,
  "type": "module",
  "dependencies": {
    "@fontsource/monaspace-neon": "^5.2.5",
    "astro": "^6.2.1"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "content:validate": "node scripts/validate-content.mjs",
    "build": "npm run content:validate && astro build",
    "preview": "astro preview --host 0.0.0.0",
    "serve": "python3 -m http.server 8080 --directory public"
  }
}
