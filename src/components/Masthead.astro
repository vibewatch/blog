---
import { config, sitePath } from '../lib/site';

const navLinks = [
  { href: '/', label: 'Front Page' },
  { href: '/about/', label: 'About' },
  { href: '/feed.xml', label: 'RSS' },
];
---

<header class="masthead">
  <div class="container">
    <a class="masthead__nameplate" href={sitePath('/')}>{config.title}</a>
    {config.description ? <p class="masthead__motto">“{config.description}”</p> : null}
    <hr class="rule rule--double" />
    <nav class="masthead__nav" aria-label="Sections">
      {navLinks.map((link) => (
        <a href={sitePath(link.href)}>{link.label}</a>
      ))}
    </nav>
    <hr class="rule" />
  </div>
</header>
