---
import '../styles/global.css';
import Masthead from '../components/Masthead.astro';
import Colophon from '../components/Colophon.astro';
import { config, absoluteUrl } from '../lib/site';

type Props = {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
};

const {
  title = config.title,
  description = config.description,
  canonical = '/',
  ogImage,
} = Astro.props;

const fullTitle = title === config.title ? title : `${title} | ${config.title}`;
const ogImageUrl = ogImage ? absoluteUrl(ogImage) : undefined;
---

<!doctype html>
<html lang={config.language ?? 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f3eee2" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={absoluteUrl(canonical)} />
    <link rel="alternate" type="application/rss+xml" title={config.title} href={absoluteUrl('/feed.xml')} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!--
      Two families:
      - Instrument Serif: display + UI + body (editorial serif, italic for emphasis)
      - Martian Mono:     code (variable mono with wdth 75–112.5, wght 100–800)
    -->
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Martian+Mono:wdth,wght@75..112.5,100..800&display=swap"
    />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={absoluteUrl(canonical)} />
    {ogImageUrl ? <meta property="og:image" content={ogImageUrl} /> : null}
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
  </head>
  <body>
    <Masthead />
    <main>
      <slot />
    </main>
    <Colophon />
    <script>
      import '../scripts/mermaid';
    </script>
  </body>
</html>
