---
import '../styles/global.css';
// Self-hosted variable fonts (no FOUT / no network round-trip).
// Variable weight files cover all weights we use; italic loaded for body italics.
import '@fontsource-variable/mona-sans/wght.css';
import '@fontsource-variable/mona-sans/wght-italic.css';
// Monaspace Neon ships per-weight (no variable build); only 400 and 500 are used
// (Shiki's min-light theme emits no bold/italic tokens, body italics stay sans).
import '@fontsource/monaspace-neon/400.css';
import '@fontsource/monaspace-neon/500.css';
// Preload the Latin subsets so the browser fetches them on HTML parse,
// in parallel with the stylesheet — eliminates the visible Arial→Mona Sans swap.
import monaSansLatin from '@fontsource-variable/mona-sans/files/mona-sans-latin-wght-normal.woff2?url';
import monaSansLatinItalic from '@fontsource-variable/mona-sans/files/mona-sans-latin-wght-italic.woff2?url';
import Masthead from '../components/Masthead.astro';
import Colophon from '../components/Colophon.astro';
import { config, absoluteUrl } from '../lib/site';

type Props = {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
};

const {
  title = config.title,
  description = config.description,
  canonical = '/',
  ogImage,
} = Astro.props;

const fullTitle = title === config.title ? title : `${title} | ${config.title}`;
const ogImageUrl = ogImage ? absoluteUrl(ogImage) : undefined;
---

<!doctype html>
<html lang={config.language ?? 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f3eee2" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={absoluteUrl(canonical)} />
    <link rel="alternate" type="application/rss+xml" title={config.title} href={absoluteUrl('/feed.xml')} />

    <link rel="preload" href={monaSansLatin} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={monaSansLatinItalic} as="font" type="font/woff2" crossorigin />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={absoluteUrl(canonical)} />
    {ogImageUrl ? <meta property="og:image" content={ogImageUrl} /> : null}
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
  </head>
  <body>
    <Masthead />
    <main>
      <slot />
    </main>
    <Colophon />
    <script>
      import '../scripts/mermaid';
      import '../scripts/copy-code';
    </script>
  </body>
</html>
