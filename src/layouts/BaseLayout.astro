---
import '../styles/global.css';
// Monaspace Neon ships per-weight (no variable build); only 400 and 500 are used
// (Shiki's min-light theme emits no bold/italic tokens, body italics stay sans).
import '@fontsource/monaspace-neon/400.css';
import '@fontsource/monaspace-neon/500.css';
// Preload the Latin subsets so the browser fetches them on HTML parse.
import monaSans from '../assets/fonts/mona-sans.woff2?url';
import Masthead from '../components/Masthead.astro';
import Colophon from '../components/Colophon.astro';
import { config, absoluteUrl, sitePath } from '../lib/site';

type Props = {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
};

const {
  title = config.title,
  description = config.description,
  canonical = '/',
  ogImage,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  tags = [],
  jsonLd,
} = Astro.props;

const fullTitle = title === config.title ? title : `${title} | ${config.title}`;
const ogImageUrl = ogImage ? absoluteUrl(ogImage) : undefined;
const jsonLdPayload = jsonLd ? JSON.stringify(jsonLd).replace(/</g, '\\u003c') : '';
const rawGaId = import.meta.env.PUBLIC_GA_ID;
const gaId = typeof rawGaId === 'string' && /^G-[A-Z0-9]+$/i.test(rawGaId.trim()) ? rawGaId.trim() : '';
const enableGa = Boolean(gaId) && import.meta.env.PROD;
---

<!doctype html>
<html lang={config.language ?? 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f3eee2" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={absoluteUrl(canonical)} />
    <link rel="icon" type="image/svg+xml" href={sitePath('/favicon.svg')} />
    <link rel="alternate" type="application/rss+xml" title={config.title} href={absoluteUrl('/feed.xml')} />

    <link rel="preload" href={monaSans} as="font" type="font/woff2" crossorigin />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={absoluteUrl(canonical)} />
    {ogImageUrl ? <meta property="og:image" content={ogImageUrl} /> : null}
    {publishedTime ? <meta property="article:published_time" content={publishedTime} /> : null}
    {modifiedTime ? <meta property="article:modified_time" content={modifiedTime} /> : null}
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    {ogImageUrl ? <meta name="twitter:image" content={ogImageUrl} /> : null}
    {jsonLdPayload ? <script type="application/ld+json" set:html={jsonLdPayload} /> : null}
    {enableGa && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${gaId}');`} />
      </>
    )}
  </head>
  <body>
    <Masthead />
    <main>
      <slot />
    </main>
    <Colophon />
    <script>
      import '../scripts/mermaid';
      import '../scripts/copy-code';
      import '../scripts/article-enhancements';
    </script>
  </body>
</html>
