---
import '../styles/global.css';
import { config, sitePath, absoluteUrl } from '../lib/site';

type Props = {
  title?: string;
  description?: string;
  canonical?: string;
};

const { title = config.title, description = config.description, canonical = '/' } = Astro.props;
const fullTitle = title === config.title ? title : `${title} | ${config.title}`;
---

<!doctype html>
<html lang={config.language ?? 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={absoluteUrl(canonical)} />
    <link rel="alternate" type="application/rss+xml" title={config.title} href={absoluteUrl('/feed.xml')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={absoluteUrl(canonical)} />
  </head>
  <body>
    <header class="topbar">
      <div class="container topbar__inner">
        <a class="brand" href={sitePath('/')} aria-label={config.title}>
          <span class="brand__mark">B</span>
          <span>{config.title}</span>
        </a>
        <nav class="nav" aria-label="Primary navigation">
          <a href={sitePath('/')}>Latest</a>
          <a href={sitePath('/about/')}>About</a>
          <a href={sitePath('/feed.xml')}>RSS</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer__inner">
        <div>© {new Date().getUTCFullYear()} {config.author ?? config.title}</div>
        <a href={sitePath('/feed.xml')}>RSS</a>
      </div>
    </footer>
    <script type="module">
      const mermaidBlocks = document.querySelectorAll('pre > code.language-mermaid');
      if (mermaidBlocks.length > 0) {
        const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');

        const fontStack = '"Inter", "Noto Sans SC", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif';

        mermaid.initialize({
          startOnLoad: false,
          securityLevel: 'strict',
          theme: 'base',
          fontFamily: fontStack,
          themeVariables: {
            background: '#ffffff',
            primaryColor: '#ffffff',
            primaryTextColor: '#1f1f1f',
            primaryBorderColor: '#1f1f1f',
            secondaryColor: '#fff5f7',
            secondaryTextColor: '#1f1f1f',
            secondaryBorderColor: '#ff385c',
            tertiaryColor: '#f7f7f7',
            tertiaryTextColor: '#1f1f1f',
            tertiaryBorderColor: '#c1c1c1',
            lineColor: '#5f5f5f',
            edgeLabelBackground: '#ffffff',
            clusterBkg: '#fafafa',
            clusterBorder: '#dddddd',
            titleColor: '#1f1f1f',
            noteBkgColor: '#fff8e1',
            noteBorderColor: '#e6c98a',
            noteTextColor: '#1f1f1f',
            actorBkg: '#ffffff',
            actorBorder: '#1f1f1f',
            actorTextColor: '#1f1f1f',
            actorLineColor: '#5f5f5f',
            signalColor: '#1f1f1f',
            signalTextColor: '#1f1f1f',
            labelBoxBkgColor: '#fff5f7',
            labelBoxBorderColor: '#ff385c',
            labelTextColor: '#1f1f1f',
            loopTextColor: '#1f1f1f',
            sectionBkgColor: '#fafafa',
            altSectionBkgColor: '#ffffff',
            gridColor: '#ebebeb',
            git0: '#ff385c',
            git1: '#1f1f1f',
            git2: '#5f5f5f',
            git3: '#929292',
            fontSize: '15px',
            fontFamily: fontStack
          },
          themeCSS: `
            .node rect, .node circle, .node ellipse, .node polygon, .node path { stroke-width: 1.25px; }
            .cluster rect { stroke-dasharray: 0; rx: 12; ry: 12; }
            .cluster .nodeLabel, .cluster .label { font-weight: 600; letter-spacing: 0.01em; }
            .edgePath .path { stroke-width: 1.5px; }
            .arrowheadPath, marker path { fill: #5f5f5f; stroke: none; }
            .edgeLabel { padding: 2px 6px; border-radius: 4px; font-size: 13px; color: #5f5f5f; }
            .edgeLabel rect { fill: #ffffff !important; }
            .label foreignObject { overflow: visible; }
            .nodeLabel, .label { font-weight: 500; }
            .marker.cross { stroke: #5f5f5f; }
          `,
          flowchart: {
            curve: 'basis',
            padding: 18,
            nodeSpacing: 50,
            rankSpacing: 60,
            htmlLabels: true,
            useMaxWidth: true,
            diagramPadding: 12
          },
          sequence: {
            useMaxWidth: true,
            actorMargin: 60,
            boxMargin: 12,
            messageMargin: 40,
            mirrorActors: false
          },
          gantt: { useMaxWidth: true },
          journey: { useMaxWidth: true },
          class: { useMaxWidth: true },
          state: { useMaxWidth: true },
          er: { useMaxWidth: true }
        });

        mermaidBlocks.forEach((code, i) => {
          const pre = code.parentElement;
          const container = document.createElement('div');
          container.className = 'mermaid';
          container.id = `mermaid-${i}`;
          container.textContent = code.textContent;
          pre.replaceWith(container);
        });

        await mermaid.run({ querySelector: '.mermaid' });
      }
    </script>
  </body>
</html>