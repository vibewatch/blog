---
import '../styles/slides.css';
import '@fontsource/monaspace-neon/400.css';
import '@fontsource/monaspace-neon/500.css';
import type { SlideDeck } from '../lib/slides/schema';
import { absoluteUrl, config, sitePath } from '../lib/site';

type Props = {
  deck: SlideDeck;
  canonical: string;
};

const { deck, canonical } = Astro.props;
const fullTitle = `${deck.title} | Slides | ${config.title}`;
const description = deck.subtitle || `Presentation slides for ${deck.title}`;
---

<!doctype html>
<html lang={config.language ?? 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f3eee2" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={absoluteUrl(canonical)} />
    <link rel="icon" type="image/svg+xml" href={sitePath('/favicon.svg')} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={absoluteUrl(canonical)} />
  </head>
  <body class="slide-body" data-deck-slug={deck.slug}>
    <slot />
  </body>
</html>
