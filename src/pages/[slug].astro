---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllItems } from '../lib/content';
import { formatDate, sitePath } from '../lib/site';

export function getStaticPaths() {
  return getAllItems().map((item) => ({
    params: { slug: item.slug },
    props: { item }
  }));
}

const { item } = Astro.props;
const Content = item.Content;
const canonical = `/${item.slug}/`;
const description = item.excerpt || item.title;
const author = item.authors[0];
const isPage = item.type === 'page';
const deskName = isPage ? 'Page' : item.desk?.desk.name ?? 'Dispatch';
const sectionId = isPage ? '' : item.desk?.sectionId ?? '';
---

<BaseLayout
  title={item.title}
  description={description}
  canonical={canonical}
  ogImage={item.featureImage || undefined}
>
  <article class="post-shell">
    <header class="post-header reading">
      <p class="post-header__category">
        <span class="post-header__desk">{deskName}</span>
        {sectionId ? <span class="post-header__section">{sectionId}</span> : null}
      </p>
      <h1 class="post-title">{item.title}</h1>
      {item.excerpt ? <p class="post-deck">{item.excerpt}</p> : null}
      <p class="post-meta">
        {author ? <>By <strong>{author}</strong></> : null}
        <time datetime={item.date.toISOString()}>{formatDate(item.date)}</time>
        {item.type === 'post' ? (
          <span class="post-meta__readtime">{item.readingTime} min read</span>
        ) : null}
      </p>
    </header>

    {item.featureImage ? (
      <figure class="reading-wide" style="margin: 0 auto var(--space-xxl);">
        <img class="feature-image" src={sitePath(item.featureImage)} alt="" loading="lazy" decoding="async" />
        <figcaption class="feature-image-caption">{item.title}</figcaption>
      </figure>
    ) : null}

    <div class:list={['article', `article--${item.type}`, `article--${item.slug}`]}>
      <Content />
    </div>

    <nav class="post-back reading" aria-label="Back to front page">
      <a href={sitePath('/')}>← Return to Front Page</a>
    </nav>
  </article>
</BaseLayout>
