---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllItems, getPostContext } from '../lib/content';
import { absoluteUrl, config, formatDate, sitePath } from '../lib/site';
import { slugify } from '../lib/slug';
import { getSlideDeckByArticle } from '../lib/slides/load';

export function getStaticPaths() {
  return getAllItems().map((item) => ({
    params: { slug: item.slug },
    props: { item }
  }));
}

const { item } = Astro.props;
const Content = item.Content;
const canonical = `/${item.slug}/`;
const description = item.excerpt || item.title;
const author = item.authors[0];
const isPage = item.type === 'page';
const deskName = isPage ? 'Page' : item.desk?.desk.name ?? 'Dispatch';
const sectionId = isPage ? '' : item.desk?.sectionId ?? '';
const postContext = isPage ? undefined : getPostContext(item.slug);
const showToc = item.type === 'post' && item.headings.length >= 2;
const articleUrl = absoluteUrl(canonical);
const jsonLd = item.type === 'post'
  ? [
      {
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: item.title,
        description,
        url: articleUrl,
        datePublished: item.date.toISOString(),
        author: author ? { '@type': 'Person', name: author } : undefined,
        image: item.featureImage ? absoluteUrl(item.featureImage) : undefined,
        keywords: item.tags.join(', '),
        articleSection: deskName,
        publisher: { '@type': 'Organization', name: config.title }
      },
      {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: config.title, item: absoluteUrl('/') },
          { '@type': 'ListItem', position: 2, name: deskName, item: absoluteUrl(`/desk/${item.desk?.deskKey ?? ''}/`) },
          { '@type': 'ListItem', position: 3, name: item.title, item: articleUrl }
        ]
      }
    ]
  : undefined;
const slideDeck = isPage ? undefined : getSlideDeckByArticle(item.slug);
const slideHref = slideDeck ? sitePath(`/slides/${slideDeck.slug}/`) : '';
---

<BaseLayout
  title={item.title}
  description={description}
  canonical={canonical}
  ogImage={item.featureImage || undefined}
  ogType={item.type === 'post' ? 'article' : 'website'}
  publishedTime={item.type === 'post' ? item.date.toISOString() : undefined}
  tags={item.tags}
  jsonLd={jsonLd}
>
  {item.type === 'post' ? <div class="reading-progress" data-reading-progress></div> : null}
  <article class="post-shell">
    <header class="post-header reading">
      <p class="post-header__category">
        <span class="post-header__desk">{deskName}</span>
        {sectionId ? <span class="post-header__section">{sectionId}</span> : null}
      </p>
      <h1 class="post-title">{item.title}</h1>
      {item.excerpt ? <p class="post-deck">{item.excerpt}</p> : null}
      {item.series ? (
        <p class="post-series">
          Part of <a href={sitePath(`/series/${item.series.slug}/`)}>{item.series.name}</a>
          {item.series.order ? <> · Part {item.series.order}</> : null}
        </p>
      ) : null}
      <p class="post-meta">
        {author ? <>By <strong>{author}</strong></> : null}
        <time datetime={item.date.toISOString()}>{formatDate(item.date)}</time>
        {item.type === 'post' ? (
          <span class="post-meta__readtime">{item.readingTime} min read</span>
        ) : null}
      </p>
      {item.tags.length ? (
        <ul class="post-tags" aria-label="Tags">
          {item.tags.map((tag) => <li><a href={sitePath(`/tags/${slugify(tag)}/`)}>{tag}</a></li>)}
        </ul>
      ) : null}
      {slideDeck ? (
        <p class="post-presentation">
          <a href={slideHref}>Open the slide deck →</a>
        </p>
      ) : null}
    </header>

    {item.featureImage ? (
      <figure class="reading-wide" style="margin: 0 auto var(--space-xxl);">
        <img class="feature-image" src={sitePath(item.featureImage)} alt="" loading="lazy" decoding="async" />
        <figcaption class="feature-image-caption">{item.title}</figcaption>
      </figure>
    ) : null}

    {showToc ? (
      <nav class="post-toc reading" aria-label="Table of contents" data-toc>
        <p class="post-toc__label">In this dispatch</p>
        <ol>
          {item.headings.map((heading) => (
            <li class:list={[heading.depth === 3 ? 'is-subsection' : null]}>
              <a href={`#${heading.slug}`}>{heading.text}</a>
            </li>
          ))}
        </ol>
      </nav>
    ) : null}

    <div class:list={['article', `article--${item.type}`, `article--${item.slug}`]}>
      <Content />
    </div>

    {postContext?.seriesPosts.length ? (
      <section class="post-series-panel reading" aria-label="More in this series">
        <p class="post-series-panel__label">More in {item.series?.name}</p>
        <ol>
          {postContext.seriesPosts.map((post) => (
            <li><a href={sitePath(`/${post.slug}/`)}>{post.title}</a></li>
          ))}
        </ol>
      </section>
    ) : null}

    {postContext ? (
      <nav class="post-neighbors reading" aria-label="Adjacent dispatches">
        {postContext.older ? (
          <a href={sitePath(`/${postContext.older.slug}/`)}>
            <span>Older</span>
            <strong>{postContext.older.title}</strong>
          </a>
        ) : <span></span>}
        {postContext.newer ? (
          <a href={sitePath(`/${postContext.newer.slug}/`)}>
            <span>Newer</span>
            <strong>{postContext.newer.title}</strong>
          </a>
        ) : <span></span>}
      </nav>
    ) : null}

    {postContext?.related.length ? (
      <section class="related-posts reading-wide" aria-label="Related dispatches">
        <header class="related-posts__head">
          <p>Related dispatches</p>
        </header>
        <div class="related-posts__grid">
          {postContext.related.map((post) => (
            <article class="related-card">
              <p>{post.desk?.sectionId ?? post.desk?.desk.name}</p>
              <h2><a href={sitePath(`/${post.slug}/`)}>{post.title}</a></h2>
              {post.excerpt ? <span>{post.excerpt}</span> : null}
            </article>
          ))}
        </div>
      </section>
    ) : null}

    <nav class="post-back reading" aria-label="Back to front page">
      <a href={sitePath('/')}>← Return to Front Page</a>
    </nav>
  </article>
</BaseLayout>
